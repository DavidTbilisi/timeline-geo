{
  "name": "timeline-geo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "extract": "node scripts/extractEvents.mjs",
    "fetch:details": "node scripts/fetchDetails.mjs",
    "fetch:images": "node scripts/fetchImages.mjs",
    "fetch:fonts": "node scripts/fetchFonts.mjs",
    "translate:export": "node scripts/translateDetails.mjs --export",
    "translate:import": "node scripts/translateDetails.mjs --import",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed"
  },
  "dependencies": {
    "pinia": "^2.2.0",
    "vue": "^3.5.30",
    "vue-i18n": "^9.13.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.0",
    "node-html-parser": "^6.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.5"
  }
}
